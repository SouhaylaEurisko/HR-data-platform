WHERE (COALESCE(a.current_address, '') ILIKE '%lebanon%' OR COALESCE(a.current_address, '') ILIKE '%lebanese%' OR COALESCE(a.custom_fields::text, '') ILIKE '%lebanon%' OR COALESCE(a.custom_fields::text, '') ILIKE '%lebanese%')
LIMIT 5
  Aggregation Sql:      SELECT COUNT(DISTINCT c.id) AS total_candidates
FROM candidates c
INNER JOIN applications a ON a.candidate_id = c.id
WHERE (COALESCE(a.current_address, '') ILIKE '%lebanon%' OR COALESCE(a.current_address, '') ILIKE '%lebanese%' OR COALESCE(a.custom_fields::text, '') ILIKE '%lebanon%' OR COALESCE(a.custom_fields::text, '') ILIKE '%lebanese%')
