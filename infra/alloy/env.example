# Grafana Cloud → your stack → Prometheus → remote write endpoint.
# Never commit real keys.
#
# For systemd Alloy on the host, copy these lines to e.g. /etc/alloy/grafana-cloud.env
# (mode 600) and reference it from the alloy.service unit:
#   EnvironmentFile=-/etc/alloy/grafana-cloud.env
# Then install infra/alloy/config.alloy as /etc/alloy/config.alloy and restart alloy.

GRAFANA_CLOUD_PROMETHEUS_REMOTE_WRITE_URL=https://prometheus-prod-XX-XX.grafana.net/api/prom/push
GRAFANA_CLOUD_PROMETHEUS_USER=123456
GRAFANA_CLOUD_PROMETHEUS_API_KEY=glc_your_token_here
